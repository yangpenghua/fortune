# ==========================================
# 豆包 API 配置
# ==========================================
# 从火山引擎获取 API Key
DOUBAO_API_KEY=your_api_key_here

# 豆包 API 基础 URL（可选，默认已配置）
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 豆包模型 ID（可选，默认已配置）
DOUBAO_MODEL=ep-20241203xxxxxx-xxxxx

# ==========================================
# 站点配置
# ==========================================
# 生产环境的站点 URL
NEXT_PUBLIC_SITE_URL=https://your-domain.com
